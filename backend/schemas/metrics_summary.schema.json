{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MetricsSummary",
  "type": "object",
  "required": ["algorithm_id", "delivery_id", "path_cost", "execution_time_ms", "nodes_explored", "path_length", "path_found", "heuristic_used"],
  "properties": {
    "algorithm_id":      { "type": "string", "enum": ["bfs", "dfs", "ucs", "greedy", "astar"] },
    "delivery_id":       { "type": "string" },
    "path_cost":         { "type": "number", "minimum": 0 },
    "execution_time_ms": { "type": "number", "minimum": 0 },
    "nodes_explored":    { "type": "integer", "minimum": 0 },
    "path_length":       { "type": "integer", "minimum": 0 },
    "path_found":        { "type": "boolean" },
    "path": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "heuristic_used": { "type": "string" }
  },
  "additionalProperties": false
}
